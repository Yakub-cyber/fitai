# Порт AI-микросервиса
AI_PORT=5001

# Ключ и OpenAI-совместимый эндпоинт. Если ключ пуст — сервис работает в mock-режиме.
# Примеры провайдеров:
#   ProxyAPI: AI_BASE_URL=https://api.proxyapi.ru/openai/v1  AI_MODEL=gpt-4o-mini
#   OpenAI:   AI_BASE_URL=https://api.openai.com/v1          AI_MODEL=gpt-4o-mini
#   DeepSeek: AI_BASE_URL=https://api.deepseek.com           AI_MODEL=deepseek-chat
AI_API_KEY=
AI_BASE_URL=https://api.proxyapi.ru/openai/v1
AI_MODEL=gpt-4o-mini

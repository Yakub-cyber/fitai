# Токен от @BotFather (BotFather → /newbot → скопировать).
BOT_TOKEN=

# Общий секрет, тот же что и BOT_SHARED_SECRET в server/.env.
BOT_SHARED_SECRET=

# URL бэкенда. Локально: http://localhost:5000. В LAN: http://192.168.X.X:5000.
API_URL=http://localhost:5000

# Публичный URL веб-приложения (для инлайн-кнопки «Открыть в браузере»).
# По умолчанию — задеплоенный GitHub Pages сайт.
WEB_URL=https://yakub-cyber.github.io/fitai/

# URL Telegram Mini App (пока пусто — включим когда сделаем TMA + туннель).
TMA_URL=

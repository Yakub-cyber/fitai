{
  "name": "fitai",
  "private": true,
  "workspaces": [
    "server",
    "ai-service",
    "web",
    "bot"
  ],
  "scripts": {
    "dev": "concurrently -n ai,server,web,bot -c blue,green,magenta,yellow \"npm:dev:ai\" \"npm:dev:server\" \"npm:dev:web\" \"npm:dev:bot\"",
    "dev:no-bot": "concurrently -n ai,server,web -c blue,green,magenta \"npm:dev:ai\" \"npm:dev:server\" \"npm:dev:web\"",
    "start": "concurrently -n ai,server,bot -c blue,green,yellow \"npm:start -w ai-service\" \"npm:start -w server\" \"npm:start -w bot\"",
    "dev:server": "npm run dev -w server",
    "dev:ai": "npm run dev -w ai-service",
    "dev:web": "npm run dev -w web",
    "dev:bot": "npm run dev -w bot",
    "typecheck": "npm run typecheck -w ai-service && npm run typecheck -w server && npm run typecheck -w web && npm run typecheck -w bot",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}

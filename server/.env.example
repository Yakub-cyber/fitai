# Порт API Gateway
PORT=5000

# Окружение: development | production.
# В production включаются строгие проверки (см. assertProdConfig в config.ts):
# запрещён дефолтный JWT_SECRET, требуется ALLOWED_ORIGINS и внешняя БД.
NODE_ENV=development

# Секрет для подписи JWT — ОБЯЗАТЕЛЬНО смените в продакшене.
# Сгенерировать: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=dev-secret-change-me

# Разрешённые origin'ы для CORS (через запятую). Пусто = разрешить всем (только dev).
# Пример для прода: ALLOWED_ORIGINS=https://fitai.app,https://www.fitai.app
ALLOWED_ORIGINS=

# Адрес AI-микросервиса
AI_SERVICE_URL=http://localhost:5001

# Раздавать собранный фронт из этого же сервиса (деплой одним сервисом, один домен).
# Тогда CORS не нужен, а фронт ходит на относительный /api.
# Перед стартом: npm run build -w web
SERVE_WEB=false
# Необязательно: путь к сборке фронта (по умолчанию ../web/dist рядом с server).
# WEB_DIST_PATH=

# --- База данных ---
# По умолчанию встроенная MongoDB без Docker (данные в server/data/mongo).
EMBEDDED_MONGO=true
MONGO_URI=mongodb://localhost:27017/fitai

# Для прода — внешняя БД (MongoDB Atlas):
#   EMBEDDED_MONGO=false
#   MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/fitai
EMBEDDED_DB_PATH=./data/mongo

# --- Telegram Bot ---
# Общий секрет, которым бот доказывает серверу свою идентичность
# (использует /api/telegram/consume-code и /api/telegram/from-id).
# Придумайте длинную строку и продублируйте её в bot/.env.
# Пусто = бот-эндпоинты выключены (503).
# Сгенерировать: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BOT_SHARED_SECRET=
